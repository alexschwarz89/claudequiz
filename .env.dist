# Quiz question provider: API | WIKIPEDIA | FILE
QUIZ_PROVIDER=API

# OpenTrivia API URLs (used when QUIZ_PROVIDER=API)
OPENTRIVIA_URL_DE=https://api.opentrivia.de
OPENTRIVIA_URL_EN=https://opentdb.com/api.php

# OpenTrivia category IDs, comma-separated (used when QUIZ_PROVIDER=API)
OPENTRIVIA_CATEGORIES=9,10,11,12,15,17,18,19,20,21,22,23,26,27,28,30,32

# JSON file path, relative to project root (used when QUIZ_PROVIDER=FILE)
QUESTION_FILE_PATH=data/custom_questions.json

# Anthropic API (used when QUIZ_PROVIDER=WIKIPEDIA)
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Wikipedia topic exclusion filter — comma-separated category keywords to skip (used when QUIZ_PROVIDER=WIKIPEDIA)
# Articles are skipped when any of their Wikipedia categories contains one of these keywords (case-insensitive substring match).
# Browse available category names at:
#   DE: https://de.wikipedia.org/wiki/Kategorie:Wikipedia:Exzellent
#   EN: https://en.wikipedia.org/wiki/Category:Featured_articles
# Examples: click any article, then "Kategorien" at the bottom to see the category names for that article.
WIKIPEDIA_EXCLUDE_TOPICS_DE=Geschichte,Krieg,Schlacht,Sport,Fußball,Kunst,Maler,Gemälde,Bildhauer
WIKIPEDIA_EXCLUDE_TOPICS_EN=history,war,battle,sport,football,art,painting,sculptor

# DeepL translation API (used when QUIZ_PROVIDER=API and lang != en)
DEEPL_API_KEY=
DEEPL_API_URL_FREE=https://api-free.deepl.com/v2/translate
DEEPL_API_URL_PRO=https://api.deepl.com/v2/translate

# REST Countries API (used for flag_mc category)
REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1

# Flag category scope: europe | world
FLAG_SCOPE=world

# Minimum population filter for flag_mc category
FLAG_MIN_POPULATION_EUROPE=1000000
FLAG_MIN_POPULATION_WORLD=10000000

# Deezer chart URL (used for song_guess category)
DEEZER_CHART_URL=https://api.deezer.com/chart/0/tracks

# Wikidata SPARQL endpoint (used for location category)
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

# Wikidata quality and fetch parameters for location category
WIKIDATA_MIN_SITELINKS=50
WIKIDATA_FETCH_LIMIT=300
# Maximum locations per country — prevents geographic clustering (e.g. many spots from Iraq/Italy)
LOCATION_MAX_PER_COUNTRY=3

# Image provider for image_reveal category: pixabay | wikimedia (default: pixabay)
# Pixabay: fast, requires PIXABAY_API_KEY. Rate limit: 100 requests per 60 seconds
# Wikimedia: slower, no API key required. Rate limit: ~1 request per 1.5 seconds
IMAGE_PROVIDER=pixabay

# Pixabay API (required when IMAGE_PROVIDER=pixabay)
PIXABAY_API_KEY=
PIXABAY_API_URL=https://pixabay.com/api/

# Wikimedia API URL (used when IMAGE_PROVIDER=wikimedia)
WIKIMEDIA_API_URL=https://en.wikipedia.org/w/api.php

# User-Agent for all Wikimedia requests (Wikipedia, Wikidata).
# Must include a contact URL or email per the Wikimedia User-Agent policy:
# https://meta.wikimedia.org/wiki/User-Agent_policy
WIKIMEDIA_USER_AGENT=ClaudeQuiz/1.0 (https://yoursite.example; contact@example.com)

# Path to wordlist file for image_reveal category (relative to project root or absolute)
WORDLIST_PATH=

# Wordlist file format: newline (one word per line) | csv (comma-separated, whitespace around entries ignored)
WORDLIST_FORMAT=newline

# YouTube Data API v3 key (required for film_scene and youtube_creator categories)
# Create one at: https://console.cloud.google.com → APIs & Services → Credentials → Create credentials → API key
# Enable the API at: APIs & Services → Library → search "YouTube Data API v3" → Enable
YOUTUBE_API_KEY=

# Minimum trailer view count for film_scene (default: 100k — TMDB popularity is the primary quality gate)
YOUTUBE_FILM_MIN_VIEWS=100000

# TMDB API key (required for film_scene — provides a curated, clean movie list)
# Free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Path to the YouTube creator channel list for youtube_creator category.
# Default: data/youtube_creators.txt (relative to project root)
# Format: one @handle or @handle|Display Name per line; lines starting with # are comments.
YOUTUBE_CREATORS_FILE=

# Path to yt-dlp binary (default: yt-dlp, assumes it is in $PATH)
# Install: pip install yt-dlp  OR  brew install yt-dlp
YTDLP_BIN=yt-dlp